{
  "name": "hakafast-server",
  "private": true,
  "version": "1.2.0",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "dev:api": "node server.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "postbuild": "node scripts/verify-build.js",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "server": "node server.js",
    "start": "node scripts/ensure-build.js && node server.js",
    "build:serve": "npm run build && node server.js",
    "verify:timing": "node scripts/verify-timing.js",
    "verify:amb": "node scripts/verify-amb-p3.js",
    "build:installer": "powershell -ExecutionPolicy Bypass -File installer/build-installer.ps1"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "nodemailer": "^8.0.10",
    "pg": "^8.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "vite": "^5.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0"
  }
}
